{
  "name": "@ellipsis/cli",
  "version": "0.1.1",
  "description": "Ellipsis agent CLI — drive the Ellipsis cloud from your terminal",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "compile": "bun build src/cli.tsx --compile --outfile agent",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.12",
    "react-devtools-core": "^4.28.5",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
